{
    "name":  "pptify-awesome-copilot-deploy",
    "targetRepository":  "https://github.com/github/awesome-copilot",
    "pluginId":  "pptify",
    "version":  "1.0.0",
    "description":  "Awesome Copilot PR artifacts for PPTify, including artifacts generated by pptify-cli.",
    "generatedWith":  {
                          "command":  "uv run python pptify-cli install --home deploy\\awesome-copilot\\plugins\\pptify",
                          "runtimeRoot":  "deploy\\awesome-copilot\\plugins\\pptify\\.agent"
                      },
    "copyRoot":  "deploy\\awesome-copilot",
    "generator":  "deploy\\create-artifacts.ps1",
    "artifacts":  [
                      "deploy\\awesome-copilot\\plugins\\pptify\\.github\\plugin\\plugin.json",
                      "deploy\\awesome-copilot\\plugins\\pptify\\README.md",
                      "deploy\\awesome-copilot\\plugins\\pptify\\.agent"
                  ],
    "validationCommands":  [
                               "npm install",
                               "npm run skill:validate",
                               "npm run plugin:validate",
                               "npm run build"
                           ]
}